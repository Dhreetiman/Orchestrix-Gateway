# ─────────────────────────────────────────────────────────────
# Orchestrix Gateway — environment configuration
# Copy to `.env` and fill in. Never commit a real `.env`.
# ─────────────────────────────────────────────────────────────

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=orchestrix
POSTGRES_PASSWORD=orchestrix_dev
POSTGRES_DB=orchestrix
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://orchestrix:orchestrix_dev@postgres:5432/orchestrix

# Redis
REDIS_URL=redis://redis:6379/0

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_TEMPERATURE=0.3

# Providers — fill in real keys to call upstream APIs
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Rate limiting — sliding window per API key, per minute. 0 disables.
RATE_LIMIT_RPM=60

# Failover
ENABLE_FAILOVER=true
MAX_REQUEST_BODY_BYTES=1048576

# CORS (comma-separated; * for dev)
CORS_ORIGINS=http://localhost:3000
